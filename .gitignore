# Terraform working directory
**/.terraform/*

# Terraform state files
*.tfstate
*.tfstate.*

# Crash logs
crash.log
crash.*.log

# Sensitive variable files (do not commit real values)
*.tfvars
!*.tfvars.example

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration files
.terraformrc
terraform.rc

# IDE/editor files
.vscode/
.idea/
*.swp
.DS_Store
